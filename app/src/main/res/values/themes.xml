<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Wachtwoordmanager" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/op_accent</item>
        <item name="colorPrimaryDark">@color/accent_donker</item>
        <item name="colorPrimaryContainer">@color/accent_licht</item>
        <item name="colorSecondary">@color/secundair</item>
        <item name="colorSurface">@color/oppervlak</item>
        <item name="colorOnSurface">@color/tekst_primair</item>
        <item name="colorOnSurfaceVariant">@color/tekst_secundair</item>
        <item name="colorOutline">@color/rand</item>
        <item name="colorError">@color/fout</item>
        <item name="android:windowBackground">@color/achtergrond</item>
        <item name="android:textColorPrimary">@color/tekst_primair</item>
        <item name="android:textColorSecondary">@color/tekst_secundair</item>
        <item name="android:statusBarColor">@color/oppervlak</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/oppervlak</item>
        <item name="android:windowActivityTransitions">true</item>
    </style>

    <!-- Login-scherm: donker immersief thema -->
    <style name="Theme.Wachtwoordmanager.Login" parent="Theme.Wachtwoordmanager">
        <item name="android:windowBackground">@color/login_achtergrond</item>
        <item name="android:statusBarColor">@color/login_achtergrond</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/login_achtergrond</item>
    </style>

    <!-- Knoppen -->
    <style name="Knop.Primair" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/op_accent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Knop.Destructief" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/fout_achtergrond</item>
        <item name="android:textColor">@color/fout</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Knop.Omlijnd" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/tekst_primair</item>
        <item name="strokeColor">@color/rand</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Knop.Tekst" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Login-specifieke knoppen -->
    <style name="Knop.Login" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/wit</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Backwards-compat aliassen -->
    <style name="BlauwKnop" parent="Knop.Primair"/>
    <style name="RoodKnop" parent="Knop.Destructief"/>
    <style name="WitKnop" parent="Knop.Omlijnd"/>
    <style name="KnopPrimair" parent="Knop.Primair"/>
    <style name="KnopDestructief" parent="Knop.Destructief"/>
    <style name="KnopOmlijnd" parent="Knop.Omlijnd"/>
    <style name="KnopTekst" parent="Knop.Tekst"/>

    <!-- Tekstvelden -->
    <style name="TekstVeld" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/rand</item>
        <item name="hintTextColor">@color/tekst_secundair</item>
        <item name="android:textColorHint">@color/tekst_tertiair</item>
        <item name="boxStrokeWidth">1.5dp</item>
    </style>

    <style name="TekstVeld.Login" parent="TekstVeld">
        <item name="boxBackgroundColor">#1F1D36</item>
        <item name="boxStrokeColor">#3D3A5C</item>
        <item name="hintTextColor">@color/tekst_op_donker_zacht</item>
        <item name="android:textColorHint">@color/tekst_op_donker_zacht</item>
    </style>

    <!-- Kaarten -->
    <style name="Kaart" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/rand</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/oppervlak</item>
    </style>

    <!-- Chips -->
    <style name="FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/oppervlak</item>
        <item name="android:textColor">@color/tekst_secundair</item>
        <item name="chipStrokeColor">@color/rand</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
    </style>
</resources>
