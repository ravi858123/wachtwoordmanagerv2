<?xml version="1.0" encoding="utf-8"?>
<!-- Item-rij: geen kaart, gewoon een rij — schoner en minder "AI-template" -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="16dp"
    android:background="?attr/selectableItemBackground">

    <!-- Gekleurde avatar-cirkel met initiaal -->
    <TextView
        android:id="@+id/tvInitiaal"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:textColor="@color/wit"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginEnd="14dp"/>

    <!-- Naam + gebruiker -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNaam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/tekst_primair"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvGebruikersnaam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/tekst_secundair"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Favoriet-ster -->
    <ImageView
        android:id="@+id/ivFavoriet"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_star_outline"
        android:layout_marginStart="8dp"
        android:padding="0dp"/>

</LinearLayout>
